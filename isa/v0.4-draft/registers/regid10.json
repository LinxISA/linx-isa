{
  "name": "regid10",
  "description": "RegId10 operand encoding namespaces for v0.4-draft. Provides decoding rules for RegId10[9:0] used by several instruction forms.",
  "bits": 10,
  "fields": [
    {
      "name": "st",
      "bits": [9],
      "description": "Signed-or-type selector (s/t). Interpretation depends on opcode family (e.g. v.add: 0=unsigned,1=signed; v.fadd: 0=float,1=reserved)."
    },
    {
      "name": "width",
      "bits": [8, 7],
      "description": "Element width tag.",
      "encoding": {
        "00": "d",
        "01": "w",
        "10": "h",
        "11": "b"
      }
    },
    {
      "name": "class",
      "bits": [6, 5],
      "description": "Register namespace selector.",
      "encoding": {
        "00": "vec",
        "01": "global_or_scalar_hand",
        "10": "loop_tile_misc",
        "11": "vec_reuse"
      }
    },
    {
      "name": "index",
      "bits": [4, 3, 2, 1, 0],
      "description": "Index within the selected class."
    }
  ],
